{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/knowledge-chunk.schema.json",
  "title": "KnowledgeChunk",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chunk_id",
    "snapshot_id",
    "source_url",
    "title",
    "section",
    "content",
    "embedding_model",
    "created_at",
    "metadata"
  ],
  "properties": {
    "chunk_id": {
      "type": "string",
      "minLength": 1
    },
    "snapshot_id": {
      "type": "string",
      "minLength": 1
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "title": {
      "type": "string"
    },
    "section": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "embedding_model": {
      "type": "string"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "domain",
        "language"
      ],
      "properties": {
        "domain": {
          "type": "string"
        },
        "language": {
          "type": "string"
        }
      }
    }
  }
}