{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/contracts/lead-payload.schema.json",
  "title": "LeadPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "correlation_id",
    "conversation_id",
    "external_user_id",
    "channel",
    "contact",
    "contact_type",
    "interest",
    "description",
    "source",
    "dedup_fingerprint",
    "created_at"
  ],
  "properties": {
    "correlation_id": {
      "type": "string",
      "minLength": 1
    },
    "conversation_id": {
      "type": "string",
      "minLength": 1
    },
    "external_user_id": {
      "type": "string",
      "minLength": 1
    },
    "channel": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": [
        "string",
        "null"
      ]
    },
    "contact": {
      "type": "string",
      "minLength": 1
    },
    "contact_type": {
      "type": "string",
      "enum": [
        "phone",
        "email",
        "username",
        "handle"
      ]
    },
    "interest": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "dedup_fingerprint": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "last_updated_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    }
  }
}