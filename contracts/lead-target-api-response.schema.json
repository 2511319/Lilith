  "title": "LeadTargetApiResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "lead_id",
    "existing_lead_id",
    "message"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "created",
        "duplicate",
        "failed"
      ]
    },
    "lead_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "existing_lead_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "message": {
      "type": "string"
    }
  }
}